# ── API Keys ────────────────────────────────────────────────────────────────
# Required for Mapillary street-level imagery. Leave empty to skip Mapillary
# (Wikimedia Commons will be used as fallback).
MAPILLARY_API_KEY=

# ── Mock mode ────────────────────────────────────────────────────────────────
# Set to true to run the full pipeline on local sample data (data/samples/).
# No live API calls are made. Ideal for local development without API keys.
# MOCK_MODE=true uvicorn app.main:app --reload
MOCK_MODE=false

# ── Job store ────────────────────────────────────────────────────────────────
# Path to the SQLite database file used to persist experience jobs.
# Jobs are available across server restarts via GET /experiences/{id}.
JOB_STORE_PATH=./data/jobs.db
# Jobs older than this many days are automatically evicted on each save().
JOB_STORE_TTL_DAYS=7

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_DIR=./data/caches
CACHE_TTL_NOMINATIM=604800
CACHE_TTL_OVERPASS=86400
CACHE_TTL_WIKIDATA=172800
CACHE_TTL_WIKIMEDIA=86400
CACHE_TTL_MAPILLARY=21600

# ── Quality gates ────────────────────────────────────────────────────────────
PIPELINE_MIN_PLACES=3
PIPELINE_IDEAL_PLACES=8
PIPELINE_STOPS_TARGET=6
PIPELINE_STOPS_MIN=3
PIPELINE_SCORE_THRESHOLD=0.40
PIPELINE_SCORE_THRESHOLD_EMERGENCY=0.25
PIPELINE_MEDIA_LOW_THRESHOLD=0.50
PIPELINE_NARRATION_MIN_TAGS=2
PIPELINE_NARRATION_WEAK_THRESHOLD=0.50

# ── Ollama LLM narration (optional) ─────────────────────────────────────────
# Opt-in LLM narration via local Ollama instance. Pipeline degrades gracefully
# to template narration if Ollama is unavailable or returns low-confidence output.
# See README for setup instructions.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3.5
OLLAMA_TIMEOUT_SECONDS=30.0

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
